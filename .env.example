# Configurações do CrewAI e LLM (Gemini)
CREWAI_MODEL=gemini-3.1-pro-preview
CREWAI_PROVIDER=google
GOOGLE_API_KEY=

# Application Configuration
APP_NAME=Recruitment Assistant
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
RECRUITMENT_EXECUTION_MODE=deterministic

# CrewAI AOP/AMP tracing
# Authenticate locally with: crewai login
CREWAI_TRACING_ENABLED=true
CREWAI_TELEMETRY_OPT_OUT=false
